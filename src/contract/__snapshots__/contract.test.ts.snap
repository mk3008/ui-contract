- color.dark.surfaceSoft: \`#1f2937\`
- color.dark.border: \`#334155\`
- color.dark.text: \`#f8fafc\`
- color.dark.mutedText: \`#cbd5e1\`

### Interaction policy

- focus.visibility: \`keyboard-and-active-inputs\`
- focus.indicatorStyle: \`outer-ring\`
- validation.trigger: \`submit-or-step\`
- validation.presentation: \`field-and-summary\`
- availability.treatment: \`keep-enabled-explain-on-action\`
- availability.layout: \`preserve-space-for-temporary-state\`
- confirmation.surface: \`danger-dialog\`
- confirmation.scope: \`destructive-only\`
- loading.feedback: \`communicate-busy-state\`
- stateFeedback.guidance: \`explain-condition-and-next-step\`

### Component policy

- button.primaryEmphasis: \`filled\`
- button.secondaryEmphasis: \`outline\`
- button.dangerPlacement: \`separated\`
- button.dangerEmphasis: \`outline\`
- button.iconAdornment: \`text-only-default\`
- button.iconOnlyPolicy: \`avoid-icon-only\`
- textField.fieldStyle: \`outlined\`
- textField.labelPlacement: \`top\`
- textField.requiredIndicator: \`mark-optional\`
- textField.messageAreaBehavior: \`reserved-message-area\`
- textField.placeholderUsage: \`avoid-placeholder\`
- select.emptyDisplay: \`placeholder-text\`
- select.multiSelectedItemDisplay: \`chips\`
- select.multiRemoveAffordance: \`chip-remove-button\`
- select.searchFieldTreatment: \`embedded-search-field\`
- tabs.treatment: \`line-tabs\`
- tabs.adornment: \`text-only\`
- toggle.treatment: \`switch-control\`
- toggle.labelPolicy: \`visible-label\`
- checkbox.choiceSurface: \`plain-label\`
- checkbox.mixedState: \`show-indeterminate\`
- card.treatment: \`outlined-card\`
- card.interaction: \`static-card\`
- sidePanel.relationship: \`persistent-inspector\`
- sidePanel.responsive: \`collapse-to-toggle\`

### Screen patterns

- searchList: \`standard-search-list\`
- formSection: \`grouped-form-section\`
"
